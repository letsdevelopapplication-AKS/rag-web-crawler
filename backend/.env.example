OPENAI_API_KEY=your_openai_api_key_here
CHROMA_PERSIST_DIR=./chroma_db
MAX_PAGES=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Account/plan data. Defaults to a local SQLite file if unset — fine for dev,
# but set this to a free hosted Postgres (e.g. Neon) for any real deployment
# so registrations survive a redeploy.
DATABASE_URL=sqlite:///./app.db
